# HexSOC AI local environment template

APP_ENV=development
APP_NAME="HexSOC AI"
API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hexsoc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://postgres:change-me@postgres:5432/hexsoc
STARTUP_SCHEMA_SYNC=auto
DATABASE_CONNECT_TIMEOUT_SECONDS=10

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=https://hexsoc-ai.vercel.app
CORS_ORIGINS=http://localhost:5173,https://hexsoc-ai.vercel.app

JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
SESSION_IDLE_TIMEOUT_MINUTES=120
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
DEMO_SEED_TOKEN=change-me-for-demo-seeding

SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=
MISP_URL=
MISP_API_KEY=
THREAT_INTEL_PROVIDER_TIMEOUT_SECONDS=8
THREAT_INTEL_PROVIDER_CACHE_TTL_SECONDS=900
THREAT_INTEL_PROVIDER_MAX_LOOKUPS_PER_REQUEST=25
OPENAI_API_KEY=

NOTIFICATIONS_ENABLED=false
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=
NOTIFICATION_RATE_LIMIT_SECONDS=300
